nt":{"children":[{"key":"label","type":"Text"},{"key":"value","type":"Text"}]}}},"content":{"default":{"children":{"code":"// Filtra os dados pelo day_of_week selecionado\r\nconst filteredData = wwFormulas.filterByKey(\r\n    collections['eb7a50b9-0b46-4438-8cf9-880c502389f7']?.['data'],\r\n    \"day_of_week\",\r\n    variables['82e49208-50e3-4dba-be47-4b081cbde98d']\r\n);\r\n\r\n// Pega o gap_minutes da configuração do evento\r\nconst gapMinutes = variables['34996dbc-27b1-4de7-94ee-f7c65f1d7d22']?.['gap_minutes'] || 60;\r\n\r\n// Função para gerar slots de horário\r\nfunction generateTimeSlots(startTime, endTime, gapMinutes) {\r\n    const slots = [];\r\n    const start = new Date(startTime);\r\n    const end = new Date(endTime);\r\n\r\n    let current = new Date(start);\r\n\r\n    while (current < end) {\r\n        const slotEnd = new Date(current.getTime() + (gapMinutes * 60 * 1000));\r\n\r\n        // Verifica se o slot não ultrapassa o horário final\r\n        if (slotEnd <= end) {\r\n            slots.push({\r\n                start: current.toISOString(),\r\n                end: slotEnd.toISOString(),\r\n                startFormatted: current.toLocaleTimeString('pt-BR', {\r\n                    hour: '2-digit',\r\n                    minute: '2-digit'\r\n                }),\r\n                endFormatted: slotEnd.toLocaleTimeString('pt-BR', {\r\n                    hour: '2-digit',\r\n                    minute: '2-digit'\r\n                }),\r\n                display: `${current.toLocaleTimeString('pt-BR', {\r\n                    hour: '2-digit',\r\n                    minute: '2-digit'\r\n                })} - ${slotEnd.toLocaleTimeString('pt-BR', {\r\n                    hour: '2-digit',\r\n                    minute: '2-digit'\r\n                })}`\r\n            });\r\n        }\r\n\r\n        current = new Date(current.getTime() + (gapMinutes * 60 * 1000));\r\n    }\r\n\r\n    return slots;\r\n}\r\n\r\n// Gera os slots para cada item filtrado\r\nconst allSlots = [];\r\n\r\nfilteredData.forEach(item => {\r\n    if (item.is_available) {\r\n        const slots = generateTimeSlots(item.start_time, item.end_time, gapMinutes);\r\n\r\n        slots.forEach(slot => {\r\n            allSlots.push({\r\n                ...slot,\r\n                originalItem: item,\r\n                event_id: item.event_id,\r\n                day_of_week: item.day_of_week\r\n            });\r\n        });\r\n    }\r\n});\r\n\r\nreturn allSlots;","__wwtype":"js","repeatable":[{"uid":"e59abfd9-584f-40e7-833a-546906e76284","isWwObject":true}],"defaultValue":[]},"_ww-layout_rowGap":"6px","_ww-layout_alignItems":"center","_ww-layout_flexDirection":"column"}},"name":"Div","wwObjectBaseId":"b783dc65-d528-4f74-8c14-e27c934c39b1","libraryComponentBaseId":null,"parentSectionId":"2866b7a2-ee90-46ad-b4a8-b7c83481804f"},"9edcf5ec-ab11-4fb2-b9f4-6245c6a8f676":{"uid":"9edcf5ec-ab11-4fb2-b9f4-6245c6a8f676","_state":{"style":{"default":{"width":{"code":"wwFormulas.if(variables['bc12bc1d-22dd-4da2-98d5-7a2c801ec85c']==context.item.data?.['startFormatted'],\"100%\",\"0%\")","__wwtype":"f","defaultValue":"100%"},"border":{"code":"wwFormulas.if(variables['bc12bc1d-22dd-4da2-98d5-7a2c801ec85c']==context.item.data?.['startFormatted'], \"1px solid #000000\", \"none\")","__wwtype":"f"},"height":"35px","padding":"6px 0 0 0","transition":"all 0.3s ease 0s","aspectRatio":"unset","borderRadius":"5px"}},"interactions":[{"id":"49998094-b1d3-4f98-8cae-b1f3e944c865","actions":{"21b71745-a97e-46aa-8b58-83fe364fa4b0":{"id":"21b71745-a97e-46aa-8b58-83fe364fa4b0","type":"if","value":{"code":"variables['bc12bc1d-22dd-4da2-98d5-7a2c801ec85c']==context.item.data?.['startFormatted']","__wwtype":"f"},"branches":[{"id":"4a805efc-d3a5-4658-80b5-5fc5aa85a453","value":true},{"value":false}]},"4a805efc-d3a5-4658-80b5-5fc5aa85a453":{"id":"4a805efc-d3a5-4658-80b5-5fc5aa85a453","args":{"data":{"end_date":{"code":"context.item.data?.['end']","__wwtype":"f"},"scheduled":{"code":"tru